# Server
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/nexus?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/nexus?schema=public"
DB_POOL_SIZE=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000

# Better Auth (required)
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (required)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (required)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# SMTP (optional, defaults below)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexus.dev

# Rate Limiting (optional, defaults below)
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=900

# Redis (optional, defaults below)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
